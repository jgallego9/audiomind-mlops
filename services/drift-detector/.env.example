# drift-detector environment variables
# Copy to services/drift-detector/.env for local development.
# In Kubernetes, inject via a Secret/ConfigMap.
#
# All settings require the DRIFT_ prefix (see app/settings.py).

# ── Qdrant ────────────────────────────────────────────────────────────────────
DRIFT_QDRANT_URL=http://qdrant:6333
DRIFT_QDRANT_COLLECTION=transcriptions
DRIFT_QDRANT_SAMPLE_SIZE=500
DRIFT_QDRANT_REFERENCE_SIZE=500

# ── Prometheus Push Gateway ────────────────────────────────────────────────────
DRIFT_PUSHGATEWAY_URL=http://prometheus-pushgateway.monitoring.svc.cluster.local:9091
DRIFT_JOB_NAME=inferflow_drift_detector

# ── Thresholds ─────────────────────────────────────────────────────────────────
DRIFT_DRIFT_THRESHOLD=0.5
