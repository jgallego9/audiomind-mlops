# AudioMind MLOps — root environment variables for docker-compose
# Copy to .env and fill in real values. Never commit .env.
#
# Usage:
#   cp .env.example .env

# ── api-gateway ──────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=change-me-before-any-real-use

# ── Optional port overrides ───────────────────────────────────────────────────
# API_GATEWAY_PORT=8000
# REDIS_PORT=6379
# QDRANT_HTTP_PORT=6333
# QDRANT_GRPC_PORT=6334
# JAEGER_UI_PORT=16686

# ── MLOps profile ─────────────────────────────────────────────────────────────
# POSTGRES_PASSWORD=mlflow-dev
# MLFLOW_PORT=5001

# ── Models profile ────────────────────────────────────────────────────────────
# WHISPER_MODEL=tiny    # tiny | base | small | medium
# WHISPER_PORT=9000
# OLLAMA_PORT=11434
