# Copy to terraform.tfvars and fill in your values.
# terraform.tfvars is excluded from git — never commit project IDs or credentials.

project_id  = "my-gcp-project-id"
region      = "us-central1"
zones       = ["us-central1-a", "us-central1-b", "us-central1-f"]

cluster_name       = "audiomind"
kubernetes_version = "latest"

# CPU node pool
node_count = 1

# GPU node pool — set to 0 to disable
gpu_node_count       = 0
gpu_accelerator_type = "nvidia-tesla-t4"

# Set to false if you need to run `terraform destroy` (non-production only).
deletion_protection = false
